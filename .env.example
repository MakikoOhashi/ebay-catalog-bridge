# ---------- Shopify app ----------
# Keep SHOPIFY_APP_URL empty in local dev when using `shopify app dev`.
# Shopify CLI updates app URLs dynamically.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=write_metaobject_definitions,write_metaobjects,write_products
SHOPIFY_APP_URL=
SHOP_CUSTOM_DOMAIN=

# ---------- Postgres (Supabase / Render) ----------
# Use Supabase Transaction pooler URL for runtime.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Use direct DB URL for Prisma direct connections when needed.
DIRECT_URL="postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres"

# ---------- App runtime ----------
PORT=3000
FRONTEND_PORT=8002
NODE_ENV=development

# ---------- Cron/Auth (for /jobs/enqueue-sync in later phases) ----------
CRON_SHARED_SECRET=

# ---------- eBay OAuth ----------
EBAY_ENV=production
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_REDIRECT_URI=
EBAY_OAUTH_SCOPES=https://api.ebay.com/oauth/api_scope/sell.inventory.readonly
EBAY_OAUTH_STATE_SECRET=

EBAY_ACCEPT_LANGUAGE=en-US
